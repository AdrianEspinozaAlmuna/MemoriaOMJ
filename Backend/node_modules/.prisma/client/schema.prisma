generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model actividad {
  id_actividad            Int                       @id @default(autoincrement())
  id_encargado            Int
  titulo                  String                    @db.VarChar(255)
  descripcion             String?
  fecha                   DateTime                  @db.Date
  hora_inicio             DateTime                  @db.Time(6)
  hora_termino            DateTime?                 @db.Time(6)
  max_participantes       Int?
  lugar                   String?                   @db.VarChar(255)
  chat_bidireccional      Boolean                   @default(true)
  aprobado                Boolean                   @default(false)
  estado                  estado_actividad          @default(pendiente)
  usuario                 usuario                   @relation(fields: [id_encargado], references: [id_usuario], onUpdate: NoAction)
  actividad_mensaje       actividad_mensaje[]
  actividad_participantes actividad_participantes[]

  @@index([fecha], map: "idx_actividad_fecha")
}

model actividad_mensaje {
  id_mensaje   Int       @id @default(autoincrement())
  id_actividad Int
  id_usuario   Int
  mensaje      String
  fecha        DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  actividad    actividad @relation(fields: [id_actividad], references: [id_actividad], onDelete: Cascade, onUpdate: NoAction)
  usuario      usuario   @relation(fields: [id_usuario], references: [id_usuario], onUpdate: NoAction)
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model actividad_participantes {
  id_actividad Int
  id_usuario   Int
  rol          rol_participante
  asistio      Boolean?         @default(false)
  valoracion   Int?
  actividad    actividad        @relation(fields: [id_actividad], references: [id_actividad], onDelete: Cascade, onUpdate: NoAction)
  usuario      usuario          @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction)

  @@id([id_actividad, id_usuario])
}

model grupo {
  id_grupo            Int                   @id @default(autoincrement())
  id_lider            Int
  nombre              String                @unique @db.VarChar(255)
  descripcion         String?
  usuario             usuario               @relation(fields: [id_lider], references: [id_usuario], onUpdate: NoAction)
  participantes_grupo participantes_grupo[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model notificaciones {
  id_notificacion Int               @id @default(autoincrement())
  id_usuario      Int
  id_sistema      Int?
  id_actividad    Int?
  tipo            tipo_notificacion
  titulo          String            @db.VarChar(255)
  descripcion     String?
  fecha_envio     DateTime          @default(now()) @db.Timestamptz(6)
  usuario         usuario           @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction)

  @@index([id_usuario], map: "idx_notificaciones_usuario")
}

model participantes_grupo {
  id_grupo   Int
  id_usuario Int
  rol        rol_grupo
  grupo      grupo     @relation(fields: [id_grupo], references: [id_grupo], onDelete: Cascade, onUpdate: NoAction)
  usuario    usuario   @relation(fields: [id_usuario], references: [id_usuario], onDelete: Cascade, onUpdate: NoAction)

  @@id([id_grupo, id_usuario])
}

model usuario {
  id_usuario              Int                       @id @default(autoincrement())
  rut                     String                    @unique @db.VarChar(12)
  nombre                  String                    @db.VarChar(100)
  apellido                String                    @db.VarChar(100)
  mail                    String                    @unique @db.VarChar(255)
  telefono                String?                   @db.VarChar(20)
  estado                  Boolean                   @default(true)
  rol                     rol_usuario
  fecha_registro          DateTime                  @default(dbgenerated("CURRENT_DATE")) @db.Date
  actividad               actividad[]
  actividad_mensaje       actividad_mensaje[]
  actividad_participantes actividad_participantes[]
  grupo                   grupo[]
  notificaciones          notificaciones[]
  participantes_grupo     participantes_grupo[]

  @@index([mail], map: "idx_usuario_mail")
}

enum estado_actividad {
  pendiente
  programada
  en_curso
  finalizada
  cancelada
}

enum rol_grupo {
  lider
  miembro
}

enum rol_participante {
  encargado
  participante
}

enum rol_usuario {
  admin
  participante
}

enum tipo_notificacion {
  sistema
  actividad
}
